# Required for web search tool (Gemini with Google Search grounding)
GEMINI_API_KEY=your_gemini_api_key_here

# Required for Telegram communication
PAT_TG_BOT_TOKEN=your_telegram_bot_token
PAT_TG_CHAT_ID=your_telegram_chat_id

# Optional — API call tool
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_PAPER=true

# Optional — odds data
ODDS_API_KEY=your_odds_api_key

# Optional — Promptfoo semantic grading
GOOGLE_API_KEY=same_as_gemini_api_key
